{
  "name": "@orbitmem/contracts",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oboroxyz/orbitmem",
    "directory": "packages/contracts"
  },
  "exports": {
    ".": {
      "bun": "./abi/index.ts",
      "import": "./dist/index.js",
      "types": "./abi/index.ts"
    }
  },
  "files": [
    "abi",
    "dist"
  ],
  "scripts": {
    "build": "forge build && bash scripts/generate-abi.sh && bunx tsc -p tsconfig.build.json",
    "build:abi": "bunx tsc -p tsconfig.build.json",
    "test": "forge test -vvv",
    "test:gas": "forge test --gas-report",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
