{
  "name": "@orbitmem/sdk",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./agent": {
      "bun": "./src/agent/index.ts",
      "import": "./dist/agent/index.js",
      "types": "./src/agent/index.ts"
    },
    "./discovery": {
      "bun": "./src/discovery/index.ts",
      "import": "./dist/discovery/index.js",
      "types": "./src/discovery/index.ts"
    },
    "./transport": {
      "bun": "./src/transport/index.ts",
      "import": "./dist/transport/index.js",
      "types": "./src/transport/index.ts"
    },
    "./contracts": {
      "bun": "./src/contracts.ts",
      "import": "./dist/contracts.js",
      "types": "./src/contracts.ts"
    },
    "./types": {
      "bun": "./src/types.ts",
      "import": "./dist/types.js",
      "types": "./src/types.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orbitdb/core": "^3.0.2",
    "@orbitdb/nested-db": "^2.0.4",
    "helia": "^5.5.1",
    "libp2p": "^2.0.0",
    "@chainsafe/libp2p-gossipsub": "^14.0.0",
    "@libp2p/identify": "^3.0.0",
    "@libp2p/tcp": "^10.0.0",
    "@chainsafe/libp2p-noise": "^16.0.0",
    "@chainsafe/libp2p-yamux": "^7.0.0",
    "blockstore-level": "^2.0.0",
    "@lit-protocol/lit-node-client": "^7.0.0",
    "@lit-protocol/encryption": "^7.0.0",
    "@lit-protocol/constants": "^7.0.0",
    "@lit-protocol/auth-helpers": "^7.0.0",
    "@storacha/client": "^1.0.0",
    "@orbitmem/contracts": "workspace:*",
    "viem": "^2.0.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "bun-types": "latest",
    "typescript": "^5.5.0"
  }
}
