{
  "name": "orbitmem",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "bin": {
    "orbitmem": "./packages/cli/src/index.ts"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test packages/sdk packages/relay packages/cli apps",
    "dev": "concurrently -n relay,web -c blue,magenta \"bun run dev:relay\" \"bun run dev:web\"",
    "dev:relay": "bun run --filter @orbitmem/relay dev",
    "dev:web": "bun run --filter @orbitmem/web dev",
    "build:web": "bun run --filter @orbitmem/web build",
    "build:contracts": "bun run --filter @orbitmem/contracts build",
    "test:contracts": "bun run --filter @orbitmem/contracts test",
    "deploy:web": "bun run --filter @orbitmem/web deploy",
    "deploy:relay": "fly deploy --config packages/relay/fly.toml --dockerfile packages/relay/Dockerfile",
    "lint": "vp lint packages apps",
    "lint:fix": "vp lint --fix packages apps && vp fmt --write packages apps",
    "format": "vp fmt --write packages apps",
    "format:check": "vp fmt --check packages apps",
    "typecheck": "bun run --filter '*' typecheck",
    "cli": "bun packages/cli/src/index.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite-plus": "^0.1.11"
  }
}
