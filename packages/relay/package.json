{
  "name": "@orbitmem/relay",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./app": {
      "bun": "./src/app.ts",
      "import": "./dist/app.js",
      "types": "./src/app.ts"
    },
    "./services": {
      "bun": "./src/services/index.ts",
      "import": "./dist/services/index.js",
      "types": "./src/services/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bunx tsc -p tsconfig.build.json",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.0.0",
    "@chainsafe/libp2p-noise": "^16.0.0",
    "@chainsafe/libp2p-yamux": "^7.0.0",
    "@hono/zod-validator": "^0.4.0",
    "@libp2p/identify": "^3.0.0",
    "@libp2p/tcp": "^10.0.0",
    "@orbitdb/core": "^3.0.2",
    "@orbitdb/nested-db": "^2.0.4",
    "@orbitmem/contracts": "workspace:*",
    "@orbitmem/sdk": "workspace:*",
    "@slicekit/erc8128": "0.3.2",
    "@storacha/client": "^1.0.0",
    "blockstore-level": "^2.0.0",
    "helia": "^5.5.1",
    "hono": "^4.0.0",
    "libp2p": "^2.0.0",
    "viem": "^2.46.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@types/node": "^25.4.0",
    "bun-types": "latest",
    "typescript": "^5.5.0"
  }
}
